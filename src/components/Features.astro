---
import FeatureArticle from "./FeatureArticle.astro";
import features from "../data/features.ts";
---

<section class="mt-20 py-20 lg:mt-20">
  <div class="mx-auto mb-10 px-2 sm:w-3/4 lg:w-1/3">
    <h1 class="text-center text-3xl font-medium text-theme-blue">Features</h1>
    <p class="mt-4 text-center text-theme-gray">
      Our aim is to make it quick and easy for you to access your favorite websites. Your bookmarks
      sync between your devices so you can access them on the go.
    </p>
  </div>
  <div
    class="mx-auto flex max-w-3xl justify-around border-b border-theme-gray/50 py-6 text-theme-blue"
  >
    {features.map((feature) => <button class="cursor-pointer">{feature.title}</button>)}
  </div>
  <div class="mt-20 space-y-20 lg:mt-22 lg:space-y-52">
    <FeatureArticle
      imagePath="/src/assets/illustration-features-tab-1.png"
      orientation="imageFirst"
    >
      <Fragment slot="header">Bookmark in one click</Fragment>
      <Fragment slot="content">
        Organize your bookmarks however you like. Our simple drag-and-drop interface give you
        complete control over how you manage your favorite sites.
      </Fragment>
    </FeatureArticle>
    <!-- <FeatureArticle
      imagePath="/src/assets/illustration-features-tab-2.png"
      orientation="contentFirst"
    >
      <Fragment slot="header">Intelligent search</Fragment>
      <Fragment slot="content">
        Our powerful search feature will help you find saved sites in no time at all. No need to
        trawl through all of your bookmarks.
      </Fragment>
    </FeatureArticle>
    <FeatureArticle
      imagePath="/src/assets/illustration-features-tab-3.png"
      orientation="imageFirst"
    >
      <Fragment slot="header">Share your bookmarks</Fragment>
      <Fragment slot="content">
        Easily share your bookmarks and collections with others. Create a shareable link that you
        can send at the click of a button.
      </Fragment>
    </FeatureArticle> -->
  </div>
</section>
