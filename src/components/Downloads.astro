---
import DownloadCard from "./DownloadCard.astro";
---

<section class="lg:mt-40 lg:py-20">
  <div class="mx-auto px-2 sm:w-3/4 lg:w-1/3">
    <h1 class="text-center text-[2.0625rem] font-medium tracking-tight text-theme-blue">
      Download the extension
    </h1>
    <p class="mt-6 text-center text-lg text-theme-blue/60">
      We've got more browsers in the pipeline. Please do let us know if you've got a favorite you'd
      like us to prioritize.
    </p>
  </div>
  <div class="container mt-16 grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
    <DownloadCard imagePath="/src/assets/logo-chrome.svg" alt="Chrome" class="lg:mb-16">
      <Fragment slot="header">Add to Chrome</Fragment>
      <Fragment slot="content">Minium version 62</Fragment>
    </DownloadCard>
    <DownloadCard imagePath="/src/assets/logo-firefox.svg" alt="Firefox" class="lg:my-8">
      <Fragment slot="header">Add to Firefox</Fragment>
      <Fragment slot="content">Minium version 62</Fragment>
    </DownloadCard>
    <DownloadCard imagePath="/src/assets/logo-opera.svg" alt="Opera" class="lg:mt-16">
      <Fragment slot="header">Add to Opera</Fragment>
      <Fragment slot="content">Minium version 62</Fragment>
    </DownloadCard>
  </div>
</section>
