---
import type { HTMLAttributes } from "astro/types";

const variant = {
  primary:
    "bg-theme-purple text-theme-white hover:bg-theme-white hover:text-theme-purple outline-theme-purple",
  secondary:
    "bg-theme-gray text-theme-blue hover:bg-theme-white hover:text-theme-blue outline-theme-gray hover:outline-theme-blue font-medium",
  tertiary:
    "bg-theme-red text-theme-white hover:bg-theme-white hover:text-theme-red outline-theme-red font-medium",
};

interface Props extends HTMLAttributes<"button"> {
  theme?: keyof typeof variant;
}

const { theme = "primary", ...rest } = Astro.props as Props;
---

<button
  id={rest.id}
  type={rest.type || "button"}
  class:list={[
    "cursor-pointer rounded-sm px-6 py-3 shadow-lg outline-2 transition-colors duration-300",
    variant[theme],
    rest.class,
  ]}
>
  <slot>Button</slot>
</button>
