---
import type { HTMLAttributes } from "astro/types";

const variant = {
  primary:
    "bg-theme-purple text-theme-white hover:bg-theme-white hover:text-theme-purple hover:outline-2 hover:outline-theme-purple",
  secondary:
    "bg-theme-white text-theme-blue hover:bg-theme-white hover:text-theme-blue hover:outline-2 hover:outline-theme-blue",
  tertiary:
    "bg-theme-red text-white hover:bg-theme-white hover:text-theme-red hover:outline-2 hover:outline-theme-red",
};

interface Props extends HTMLAttributes<"button"> {
  theme?: keyof typeof variant;
}

const { theme = "primary", ...rest } = Astro.props as Props;
---

<button
  id={rest.id}
  type={rest.type || "button"}
  class:list={[
    "rounded-md px-6 py-3 shadow-md transition duration-300",
    variant[theme],
    rest.class,
  ]}
>
  <slot>Button</slot>
</button>
