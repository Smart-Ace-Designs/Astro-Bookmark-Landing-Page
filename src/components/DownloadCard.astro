---
import type { HTMLAttributes } from "astro/types";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

import Button from "./Button.astro";

interface Props extends HTMLAttributes<"div"> {
  imagePath: string;
  alt: string;
}
const { imagePath, alt, ...rest } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/*.{jpeg,jpg,png,gif,svg}");
if (!images[imagePath])
  throw new Error(`"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,svg}"`);
---

<div class:list={["flex flex-col rounded-xl shadow-md", rest.class]}>
  <div class="flex flex-col items-center p-8">
    <Image src={images[imagePath]()} loading="lazy" alt={alt} />
    <h3 class="mt-5 mb-2 text-xl font-medium text-theme-blue">
      <slot name="header" />
    </h3>
    <p class="mb-2 font-light text-theme-blue/50"><slot name="content" /></p>
  </div>
  <img src="/bg-dots.svg" alt="" loading="lazy" />
  <div class="flex p-6">
    <Button theme="primary" class="flex-1 text-sm text-theme-gray">Add & Install Extension</Button>
  </div>
</div>
